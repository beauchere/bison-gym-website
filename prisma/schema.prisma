generator client {
  provider = "prisma-client-js"
  output    = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  passwordHash     String
  role             String
  membershipStatus String?
  membershipType   String?
  bookings         Booking[]      @relation("UserBookings")
  memberships      Membership[]   @relation("UserMemberships")
  notifications    Notification[] @relation("UserNotifications")
  payments         Payment[]      @relation("UserPayments")
}

model Trainer {
  id             String    @id @default(uuid())
  name           String
  specialization String[]
  availability   Json[]
  bookings       Booking[] @relation("TrainerBookings")
}

model Booking {
  id          String     @id @default(uuid())
  userId      String
  trainerId   String?
  equipmentId String?
  date        DateTime
  time        String
  status      String
  equipment   Equipment? @relation("EquipmentBookings", fields: [equipmentId], references: [id])
  trainer     Trainer?   @relation("TrainerBookings", fields: [trainerId], references: [id])
  user        User       @relation("UserBookings", fields: [userId], references: [id])
  payment     Payment?   @relation("BookingPayment")
}

model Equipment {
  id                 String    @id @default(uuid())
  name               String
  status             String
  maintenanceHistory Json[]
  bookings           Booking[] @relation("EquipmentBookings")
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  bookingId       String?  @unique
  amount          Float
  paymentMethod   String
  transactionDate DateTime
  status          String
  booking         Booking? @relation("BookingPayment", fields: [bookingId], references: [id])
  user            User     @relation("UserPayments", fields: [userId], references: [id])
}

model Notification {
  id      String   @id @default(uuid())
  userId  String
  message String
  date    DateTime
  read    Boolean  @default(false)
  user    User     @relation("UserNotifications", fields: [userId], references: [id])
}

model Membership {
  id         String   @id @default(uuid())
  userId     String
  type       String
  status     String
  expiryDate DateTime
  user       User     @relation("UserMemberships", fields: [userId], references: [id])
}
